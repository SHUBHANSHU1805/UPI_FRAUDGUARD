# ── Copy this file to .env and fill in your own values ──────────────────────
# Never commit .env to git!

# Flask
SECRET_KEY=change-this-to-a-long-random-string-in-production
FLASK_ENV=development
FLASK_DEBUG=1

# JWT  (must be different from SECRET_KEY)
JWT_SECRET_KEY=another-long-random-string-for-jwt-signing

# SQLite DB path (relative to api/ folder)
# For production swap to PostgreSQL:
# DATABASE_URL=postgresql://user:pass@localhost:5432/fraudguard
DATABASE_URL=sqlite:///fraudguard.db
